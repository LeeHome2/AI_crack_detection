# 서버/로컬 배포 환경변수 예시. 실제 값은 .env 로 복사해 채운다 (.env 는 git·이미지에서 제외).
# CD 배포 시에는 GitHub Secrets → cd.yml 이 서버에 .env 를 생성한다.

# ── 앱 ──
APP_IMAGE=crack:local          # CD는 ghcr.io/leehome2/ai_crack_detection:sha-xxxx 로 주입
SERVICE_PORT=8501

# ── 임베딩 (RAG) ──
EMBED_PROVIDER=solar           # solar | bge(로컬 폴백) | mock(테스트)
UPSTAGE_API_KEY=               # Solar 임베딩 API 키 (provider=solar 필수)
# SOLAR_EMBED_PASSAGE=solar-embedding-1-large-passage
# SOLAR_EMBED_QUERY=solar-embedding-1-large-query

# ── 보고서 (Claude) ──
ANTHROPIC_API_KEY=             # 없으면 목업 보고서로 동작
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── RAG 튜닝 ──
RAG_MATCH_MIN_SCORE=0.55       # 실제 임베더 분포로 재보정
