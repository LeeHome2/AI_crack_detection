# 서버/로컬 배포 환경변수 예시. 실제 값은 .env 로 복사해 채운다 (.env 는 git·이미지에서 제외).
# CD 배포 시에는 GitHub Secrets → cd.yml 이 서버에 .env 를 생성한다.
# ※ 주석은 반드시 '독립된 줄'에만. 값 뒤 인라인 주석(예: KEY=값 # 설명)은 값에 딸려 들어가
#    깨질 수 있으니 쓰지 말 것.

# ── 앱 ──
# APP_IMAGE: CD는 ghcr.io/leehome2/ai_crack_detection:sha-xxxx 로 주입
APP_IMAGE=crack:local
SERVICE_PORT=8501

# ── 임베딩 (RAG) ──
# EMBED_PROVIDER: solar | bge(로컬 폴백) | mock(테스트)
EMBED_PROVIDER=solar
# UPSTAGE_API_KEY: Solar 임베딩 API 키 (provider=solar 일 때 필수). 없으면 RAG 미구축으로 동작
UPSTAGE_API_KEY=
# SOLAR_EMBED_PASSAGE=solar-embedding-1-large-passage
# SOLAR_EMBED_QUERY=solar-embedding-1-large-query

# ── 보고서 (Claude) ──
# ANTHROPIC_API_KEY: 없으면(비워두면) 목업 보고서로 동작. 있으면 실제 Claude 보고서
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── RAG 튜닝 ──
# RAG_MATCH_MIN_SCORE: 코사인 유사도 임계값(점수=1-코사인거리). Solar+코사인 실측 기준
#   관련 근거 top ~0.47~0.59 / off-topic ~0.18 → 기본 0.30. 데이터 바뀌면 rag_smoke_test 로 재관측
RAG_MATCH_MIN_SCORE=0.30
